NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Backend
PORT=3001
DATABASE_URL=postgresql://levelup:dev_password@localhost:5432/levelup
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
APP_ORIGIN=http://localhost:3000
PUBLIC_API_URL=http://localhost:3001
ADMIN_API_TOKEN=change_me_admin_token
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
DEV_TOOLS_ENABLED=false
LOCAL_UPLOADS_ENABLED=false
LOCAL_UPLOAD_DIR=.runtime/uploads

# Media storage: Cloudflare R2 or AWS S3 compatible
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=levelup-media
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PRICE_AMOUNT=300
PRICE_CURRENCY=usd

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIPTION_MODEL=whisper-1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6
TRANSCRIPTION_PROVIDER=whisper
